{{ define "dashboard" }}
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta http-equiv="refresh" content="5">
    <title>antsd administration - {{ .NodeName }}</title>
    <style>
        body {
            max-width: 960px;
            margin: 2rem auto;
            padding: 0 1rem;
            font-family: system-ui, sans-serif;
            color: #1f2937;
        }

        h1 {
            margin-bottom: 0.25rem;
        }

        .meta {
            color: #6b7280;
            margin-top: 0;
        }

        .status {
            display: inline-block;
            padding: 0.25rem 0.6rem;
            border-radius: 0.3rem;
            font-weight: 600;
        }

        .status.available {
            background: #dcfce7;
            color: #166534;
        }

        .status.unavailable {
            background: #fee2e2;
            color: #7f1d1d;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 1rem;
        }

        th, td {
            text-align: left;
            padding: 0.75rem;
            border-bottom: 1px solid #d1d5db;
        }

        th {
            background: #f3f4f6;
        }

        .member-status {
            font-weight: 600;
        }

        .empty {
            color: #6b7280;
            font-style: italic;
        }

        .tag {
            display: inline-block;
            margin: 0.1rem 0.2rem 0.1rem 0;
            padding: 0.1rem 0.4rem;
            border-radius: 0.3rem;
            background: #eef2ff;
            color: #3730a3;
            font-family: ui-monospace, monospace;
            font-size: 0.85rem;
        }
    </style>
</head>
<body>
<h1>antsd administration - {{ .NodeName }}</h1>

<p class="meta">
    Observed by <strong>{{ .NodeName }}</strong>
    at {{ .CollectedAt.Format "2006-01-02 15:04:05 MST" }}.
</p>

<p class="meta">
    antsd started at {{ .StartedAt.Format "2006-01-02 15:04:05 MST" }}
    (uptime {{ .Uptime }}).
</p>

{{ if .Available }}
<p><span class="status available">Serf available</span> {{ len .Members }} member(s) observed.</p>
{{ else }}
<p><span class="status unavailable">Serf unavailable</span></p>
{{ end }}

<h2>Members</h2>

{{ if .Members }}
<table>
    <thead>
    <tr>
        <th>Name</th>
        <th>Address</th>
        <th>Status</th>
        <th>State</th>
        <th>Tags</th>
    </tr>
    </thead>
    <tbody>
    {{ range .Members }}
    <tr>
        <td>{{ .Name }}</td>
        <td>{{ .Address }}</td>
        <td class="member-status">{{ .Status }}</td>
        <td>{{ index .Tags "state" }}</td>
        <td>
            {{ $tags := .OtherTags }}
            {{ if $tags }}
            {{ range $tags }}<span class="tag">{{ .Key }}={{ .Value }}</span>{{ end }}
            {{ else }}
            <span class="empty">-</span>
            {{ end }}
        </td>
    </tr>
    {{ end }}
    </tbody>
</table>
{{ else }}
<p class="empty">No Serf members observed yet.</p>
{{ end }}
</body>
</html>
{{end}}